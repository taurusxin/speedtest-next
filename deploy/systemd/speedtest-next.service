[Unit]
Description=Speedtest Next web service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
DynamicUser=yes
WorkingDirectory=/opt/speedtest-next
ExecStart=/opt/speedtest-next/speedtest-next
Restart=always
RestartSec=3

EnvironmentFile=-/etc/speedtest-next/speedtest-next.env

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/opt/speedtest-next

[Install]
WantedBy=multi-user.target
